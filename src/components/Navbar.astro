---
const navItems = [
  { path: '/', name: 'Home' },
  { path: '/blog', name: 'Blog' },
  { path: '/about', name: 'About' },
];
---

<aside class="-ml-[8px] mb-4 tracking-tight">
  <div class="lg:sticky lg:top-20">
    <nav
      class="flex flex-row items-start relative px-0 pb-0 fade md:overflow-auto scroll-pr-6 md:relative"
      id="nav"
    >
      <div class="flex flex-row w-full items-center space-x-0 pr-5">
        {navItems.map(({ path, name }) => (
          <a
            href={path}
            class="main-link flex align-middle relative py-1 px-2 m-1"
          >
            {name}
          </a>
        ))}
        <div class="ml-auto flex align-middle relative py-1 px-2">
          <a
            class="main-link flex items-center"
            rel="noopener noreferrer"
            target="_blank"
            href="https://x.com/KonradSalkowski"
          >
            <p class="h-7 font-medium text-2xl"><i class="fa-brands fa-x-twitter"></i></p>
          </a>
          <a
            class="main-link flex items-center"
            rel="noopener noreferrer"
            target="_blank"
            href="https://github.com/ksalk"
          >
            <p class="ml-4 h-7 font-medium text-2xl"><i class="fa-brands fa-github"></i></p>
          </a>
          <a
            class="main-link flex items-center"
            rel="noopener noreferrer"
            target="_blank"
            href="https://www.linkedin.com/in/konrad-salkowski/"
          >
            <p class="ml-4 h-7 font-medium text-2xl"><i class="fa-brands fa-linkedin"></i></p>
          </a>
        </div>
      </div>
    </nav>
  </div>
</aside>
